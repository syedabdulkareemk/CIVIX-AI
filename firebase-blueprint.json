{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents citizen profile, ranks, rep, and gamification state.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "rank": { "type": "string", "enum": ["Citizen", "Scout", "Verifier", "Inspector", "Guardian", "Community Hero"] },
        "xp": { "type": "integer" },
        "reputation": { "type": "integer" },
        "issuesReported": { "type": "integer" },
        "issuesVerified": { "type": "integer" },
        "missionsCompleted": { "type": "integer" },
        "completedMissionsList": { "type": "array" },
        "achievements": { "type": "array" }
      },
      "required": ["uid", "email", "displayName", "rank", "xp", "reputation"]
    },
    "Issue": {
      "title": "Issue",
      "description": "Represents reported community infrastructure issues.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string", "enum": ["Pothole", "Water Leakage", "Streetlight", "Waste Management", "Road Damage", "Public Safety", "Other"] },
        "severity": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "status": { "type": "string", "enum": ["Reported", "Under Verification", "Verified", "Escalated", "In Progress", "Resolved"] },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "address": { "type": "string" },
        "gpsDetected": { "type": "boolean" },
        "confidenceScore": { "type": "integer" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "verificationsCount": { "type": "integer" },
        "duplicateCount": { "type": "integer" },
        "resolutionConfirmations": { "type": "integer" },
        "verifiedUsers": { "type": "array" },
        "duplicateUsers": { "type": "array" },
        "resolverUsers": { "type": "array" },
        "timeline": { "type": "array" },
        "aiAnalysis": { "type": "object" }
      },
      "required": ["id", "title", "category", "severity", "status", "latitude", "longitude", "creatorId", "creatorName", "createdAt", "updatedAt"]
    },
    "Mission": {
      "title": "Mission",
      "description": "Represents active community missions generated by AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "targetIssueId": { "type": "string" },
        "type": { "type": "string", "enum": ["verify", "check_repair", "confirm_leak", "validate_report"] },
        "xpReward": { "type": "integer" },
        "repReward": { "type": "integer" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Completed"] }
      },
      "required": ["id", "title", "description", "type", "xpReward", "repReward", "latitude", "longitude", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Citizen profiles indexed by Auth UID."
    },
    "/issues/{issueId}": {
      "schema": "Issue",
      "description": "Reported community issues which any user can verify or read."
    },
    "/missions/{missionId}": {
      "schema": "Mission",
      "description": "Active community missions."
    }
  }
}
